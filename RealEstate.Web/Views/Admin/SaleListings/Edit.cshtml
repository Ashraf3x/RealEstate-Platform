@model RealEstate.Application.DTOs.SaleListingDto
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Listing";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5">
                    <h5 class="fw-bold mb-1">Edit Listing</h5>
                    <p class="text-muted mb-4">@Model.PropertyTitle</p>
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="ListingId" />
                        <input type="hidden" asp-for="PropertyId" />
                        <input type="hidden" asp-for="PropertyTitle" />
                        <div class="mb-3">
                            <label asp-for="PricePerShare" class="form-label fw-semibold">Price Per Share ($)</label>
                            <input asp-for="PricePerShare" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Quantity" class="form-label fw-semibold">Quantity</label>
                            <input asp-for="Quantity" class="form-control" />
                        </div>
                        <div class="mb-4">
                            <label asp-for="Status" class="form-label fw-semibold">Status</label>
                            <select asp-for="Status" class="form-select">
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                                <option value="Sold">Sold</option>
                            </select>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning flex-grow-1 text-white">Update</button>
                            <a asp-action="AdminIndex" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
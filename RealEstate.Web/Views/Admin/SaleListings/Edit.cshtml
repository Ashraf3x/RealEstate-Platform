@model RealEstate.Application.DTOs.SaleListingDto
@{
    Layout = "_AdminLayout"; ViewData["Title"] = "Edit Listing";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="AdminIndex" class="btn-glass" style="text-decoration:none;border-radius:8px;padding:7px 14px;font-size:0.83rem"><i class="fas fa-arrow-left me-1"></i> Back</a>
    <h1 class="page-title mb-0">Edit Listing</h1>
</div>
<div class="card-glass p-4" style="max-width:480px">
    <p style="color:var(--text-muted);font-size:0.85rem;margin-bottom:1.5rem">@Model.PropertyTitle</p>
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="ListingId" />
        <input type="hidden" asp-for="PropertyId" />
        <input type="hidden" asp-for="PropertyTitle" />
        <div class="mb-3"><label class="form-label-glass">Price Per Share ($)</label><input asp-for="PricePerShare" class="form-control form-control-glass" /></div>
        <div class="mb-3"><label class="form-label-glass">Quantity</label><input asp-for="Quantity" class="form-control form-control-glass" /></div>
        <div class="mb-4">
            <label class="form-label-glass">Status</label>
            <select asp-for="Status" class="form-select form-select-glass">
                <option value="Active">Active</option>
                <option value="Inactive">Inactive</option>
                <option value="Sold">Sold</option>
            </select>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn-gold flex-grow-1">Update</button>
            <a asp-action="AdminIndex" class="btn-glass" style="text-decoration:none;border-radius:8px;padding:8px 16px">Cancel</a>
        </div>
    </form>
</div>

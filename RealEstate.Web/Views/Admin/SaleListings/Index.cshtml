@model List<RealEstate.Application.DTOs.SaleListingDto>
@{
    Layout = "_AdminLayout"; ViewData["Title"] = "Manage Listings";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title mb-1">Sale Listings</h1>
        <p style="color:var(--text-muted);font-size:0.85rem;margin:0">@Model.Count total listings</p>
    </div>
    <a asp-action="Create" class="btn-gold d-flex align-items-center gap-2" style="text-decoration:none;border-radius:8px;padding:9px 18px;font-size:0.87rem;font-weight:600">
        <i class="fas fa-plus"></i> Add Listing
    </a>
</div>

<div class="card-glass">
    <table class="table-glass">
        <thead>
            <tr><th>#</th><th>Property</th><th>Price/Share</th><th>Quantity</th><th>Status</th><th>Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="color:var(--text-muted)">@item.ListingId</td>
                    <td style="font-weight:600">@item.PropertyTitle</td>
                    <td>$@item.PricePerShare</td>
                    <td>@item.Quantity</td>
                    <td>
                        @if (item.Status == "Active")
                        {
                            <span class="badge-success-glass">Active</span>
                        }
                        else if (item.Status == "Sold")
                        {

                            <span class="badge-danger-glass">Sold</span>
                        }
                        else
                        {

                            <span class="badge-muted-glass">@item.Status</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.ListingId" class="btn-warning-glass me-1" style="text-decoration:none;border-radius:6px;padding:4px 12px">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.ListingId" class="btn-danger-glass" style="text-decoration:none;border-radius:6px;padding:4px 12px">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

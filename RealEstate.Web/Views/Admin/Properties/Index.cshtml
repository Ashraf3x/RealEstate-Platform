@model List<RealEstate.Application.DTOs.PropertyDto>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Manage Properties";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">Properties</h4>
            <p class="text-muted mb-0">@Model.Count total properties</p>
        </div>
        <a asp-action="Create" class="btn btn-success px-4">+ Add Property</a>
    </div>
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="px-4 py-3">#</th>
                        <th class="py-3">Title</th>
                        <th class="py-3">Location</th>
                        <th class="py-3">Price/Share</th>
                        <th class="py-3">Shares</th>
                        <th class="py-3">Status</th>
                        <th class="py-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="px-4 py-3 text-muted">@item.PropertyId</td>
                            <td class="py-3 fw-semibold">@item.Title</td>
                            <td class="py-3">@item.Location</td>
                            <td class="py-3">$@item.PricePerShare</td>
                            <td class="py-3">@item.TotalShares</td>
                            <td class="py-3">
                                <span class="badge @(item.Status == "Active" ? "bg-success" : "bg-secondary")">
                                    @item.Status
                                </span>
                            </td>
                            <td class="py-3">
                                <a asp-action="Edit" asp-route-id="@item.PropertyId"
                                   class="btn btn-sm btn-outline-warning me-1">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.PropertyId"
                                   class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
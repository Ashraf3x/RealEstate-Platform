@model List<RealEstate.Application.DTOs.PropertyDto>
@{
    Layout = "_AdminLayout"; ViewData["Title"] = "Manage Properties";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title mb-1">Properties</h1>
        <p style="color:var(--text-muted);font-size:0.85rem;margin:0">@Model.Count total properties</p>
    </div>
    <a asp-action="Create" class="btn-gold d-flex align-items-center gap-2" style="text-decoration:none;border-radius:8px;padding:9px 18px;font-size:0.87rem;font-weight:600">
        <i class="fas fa-plus"></i> Add Property
    </a>
</div>

<div class="card-glass">
    <table class="table-glass">
        <thead>
            <tr>
                <th>#</th>
                <th>Title</th>
                <th>Location</th>
                <th>Price/Share</th>
                <th>Shares</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="color:var(--text-muted)">@item.PropertyId</td>
                    <td style="font-weight:600">@item.Title</td>
                    <td style="color:var(--text-muted)">@item.Location</td>
                    <td>$@item.PricePerShare</td>
                    <td>@item.TotalShares</td>
                    <td>
                        @if (item.Status == "Active")
                        {
                            <span class="badge-success-glass">Active</span>
                        }
                        else
                        {

                            <span class="badge-muted-glass">@item.Status</span>
                        }
                    </td>
                    <td>
                        <div class="d-flex align-items-center">
                            <a asp-action="Edit" asp-route-id="@item.PropertyId" class="btn-warning-glass me-2" style="text-decoration:none;border-radius:6px;padding:4px 12px">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.PropertyId" class="btn-danger-glass" style="text-decoration:none;border-radius:6px;padding:4px 12px">Delete</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

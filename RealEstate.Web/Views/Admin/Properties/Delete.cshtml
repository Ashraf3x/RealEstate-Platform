@model RealEstate.Application.DTOs.PropertyDto
@{
    Layout = "_AdminLayout"; ViewData["Title"] = "Delete Property";
}

<div class="d-flex justify-content-center">
    <div class="card-glass p-4 text-center" style="max-width:440px;width:100%">
        <div style="width:56px;height:56px;background:rgba(220,53,69,0.12);border:1px solid rgba(220,53,69,0.3);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.4rem;color:#ff8080"><i class="fas fa-trash-alt"></i></div>
        <h5 style="font-family:'Rajdhani',sans-serif;font-weight:700">Delete Property?</h5>
        <p style="color:var(--text-muted);font-size:0.85rem"><strong style="color:#fff">@Model.Title</strong> will be permanently removed.</p>
        <div style="background:rgba(255,255,255,0.04);border-radius:10px;padding:14px;text-align:left;margin-bottom:1.5rem;font-size:0.85rem">
            <div style="display:flex;justify-content:space-between;margin-bottom:5px"><span style="color:var(--text-muted)">Location</span><span>@Model.Location</span></div>
            <div style="display:flex;justify-content:space-between;margin-bottom:5px"><span style="color:var(--text-muted)">Price/Share</span><span>$@Model.PricePerShare</span></div>
            <div style="display:flex;justify-content:space-between">
                <span style="color:var(--text-muted)">Status</span>
                @if (Model.Status == "Active")
                {
                    <span class="badge-success-glass">Active</span>
                }
                else
                {

                    <span class="badge-muted-glass">@Model.Status</span>
                }
            </div>
        </div>
        <form asp-action="Delete" method="post">
            <input type="hidden" name="id" value="@Model.PropertyId" />
            <div class="d-flex gap-2">
                <button type="submit" style="flex:1;background:rgba(220,53,69,0.2);border:1px solid rgba(220,53,69,0.4);color:#ff8080;border-radius:8px;padding:10px;cursor:pointer;transition:all 0.2s">Delete</button>
                <a asp-action="AdminIndex" class="btn-glass flex-grow-1 text-center" style="text-decoration:none;border-radius:8px;padding:10px">Cancel</a>
            </div>
        </form>
    </div>
</div>

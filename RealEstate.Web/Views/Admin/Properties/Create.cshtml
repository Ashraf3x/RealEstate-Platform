@model RealEstate.Application.DTOs.CreatePropertyDto
@{
    Layout = "_AdminLayout"; ViewData["Title"] = "Add Property";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="AdminIndex" class="btn-glass" style="text-decoration:none;border-radius:8px;padding:7px 14px;font-size:0.83rem"><i class="fas fa-arrow-left me-1"></i> Back</a>
    <h1 class="page-title mb-0">New Property</h1>
</div>
<div class="card-glass p-4" style="max-width:560px">
    <form asp-action="Create" method="post">
        <div class="mb-3"><label class="form-label-glass">Title</label><input asp-for="Title" class="form-control form-control-glass" /><span asp-validation-for="Title" style="color:#ff8080;font-size:0.78rem"></span></div>
        <div class="mb-3"><label class="form-label-glass">Description</label><textarea asp-for="Description" class="form-control form-control-glass" rows="3"></textarea><span asp-validation-for="Description" style="color:#ff8080;font-size:0.78rem"></span></div>
        <div class="mb-3"><label class="form-label-glass">Location</label><input asp-for="Location" class="form-control form-control-glass" /><span asp-validation-for="Location" style="color:#ff8080;font-size:0.78rem"></span></div>
        <div class="row g-3 mb-3">
            <div class="col-6"><label class="form-label-glass">Total Shares</label><input asp-for="TotalShares" class="form-control form-control-glass" /></div>
            <div class="col-6"><label class="form-label-glass">Price Per Share ($)</label><input asp-for="PricePerShare" class="form-control form-control-glass" /></div>
        </div>
        <div class="mb-4">
            <label class="form-label-glass">Status</label>
            <select asp-for="Status" class="form-select form-select-glass">
                <option value="">Select status</option>
                <option value="Active">Active</option>
                <option value="Inactive">Inactive</option>
            </select>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn-gold flex-grow-1">Add Property</button>
            <a asp-action="AdminIndex" class="btn-glass" style="text-decoration:none;border-radius:8px;padding:8px 16px">Cancel</a>
        </div>
    </form>
</div>

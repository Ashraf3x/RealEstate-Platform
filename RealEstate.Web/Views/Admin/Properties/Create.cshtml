@model RealEstate.Application.DTOs.CreatePropertyDto
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add Property";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5">
                    <h5 class="fw-bold mb-1">New Property</h5>
                    <p class="text-muted mb-4">Fill in the property details</p>
                    <form asp-action="Create" method="post">
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-semibold">Title</label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Location" class="form-label fw-semibold">Location</label>
                            <input asp-for="Location" class="form-control" />
                            <span asp-validation-for="Location" class="text-danger small"></span>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <label asp-for="TotalShares" class="form-label fw-semibold">Total Shares</label>
                                <input asp-for="TotalShares" class="form-control" />
                                <span asp-validation-for="TotalShares" class="text-danger small"></span>
                            </div>
                            <div class="col-6">
                                <label asp-for="PricePerShare" class="form-label fw-semibold">Price Per Share ($)</label>
                                <input asp-for="PricePerShare" class="form-control" />
                                <span asp-validation-for="PricePerShare" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label asp-for="Status" class="form-label fw-semibold">Status</label>
                            <select asp-for="Status" class="form-select">
                                <option value="">Select status</option>
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success flex-grow-1">Add Property</button>
                            <a asp-action="AdminIndex" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
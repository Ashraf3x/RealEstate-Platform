@model RealEstate.Application.DTOs.PropertyDto
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Property";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5">
                    <h5 class="fw-bold mb-1">Edit Property</h5>
                    <p class="text-muted mb-4">@Model.Title</p>
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="PropertyId" />
                        <input type="hidden" asp-for="CreatedAt" />
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-semibold">Title</label>
                            <input asp-for="Title" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Location" class="form-label fw-semibold">Location</label>
                            <input asp-for="Location" class="form-control" />
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <label asp-for="TotalShares" class="form-label fw-semibold">Total Shares</label>
                                <input asp-for="TotalShares" class="form-control" />
                            </div>
                            <div class="col-6">
                                <label asp-for="PricePerShare" class="form-label fw-semibold">Price Per Share ($)</label>
                                <input asp-for="PricePerShare" class="form-control" />
                            </div>
                        </div>
                        <div class="mb-4">
                            <label asp-for="Status" class="form-label fw-semibold">Status</label>
                            <select asp-for="Status" class="form-select">
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning flex-grow-1 text-white">Update</button>
                            <a asp-action="AdminIndex" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
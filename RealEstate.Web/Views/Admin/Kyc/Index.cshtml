@model List<RealEstate.Domain.Entities.KycDocument>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "KYC Management";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1"><i class="bi bi-shield-check me-2"></i>KYC Management</h4>
            <p class="text-muted mb-0">@Model.Count total submissions</p>
        </div>
    </div>
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="px-4 py-3">#</th>
                        <th class="py-3">User</th>
                        <th class="py-3">Document Type</th>
                        <th class="py-3">Reference</th>
                        <th class="py-3">Status</th>
                        <th class="py-3">Submitted</th>
                        <th class="py-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in Model)
                    {
                        <tr>
                            <td class="px-4 py-3 text-muted">@doc.KycId</td>
                            <td class="py-3 fw-semibold">@doc.User?.FirstName @doc.User?.LastName</td>
                            <td class="py-3">@doc.DocumentType</td>
                            <td class="py-3 text-muted">@doc.FilePath</td>
                            <td class="py-3">
                                <span class="badge @(doc.Status == "Approved" ? "bg-success" : doc.Status == "Rejected" ? "bg-danger" : "bg-warning text-dark")">
                                    @doc.Status
                                </span>
                            </td>
                            <td class="py-3 text-muted">@doc.UploadedAt.ToString("dd MMM yyyy")</td>
                            <td class="py-3">
                                @if (doc.Status == "Pending")
                                {
                                    <form asp-action="Approve" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@doc.KycId" />
                                        <button type="submit" class="btn btn-sm btn-outline-success me-1">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                    </form>
                                    <form asp-action="Reject" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@doc.KycId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small">Done</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@using RealEstate.Domain.Entities
@model List<RealEstate.Domain.Entities.KycDocument>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "KYC Management";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1 text-white"><i class="bi bi-shield-check me-2 text-primary"></i>KYC Verification Center</h4>
            <p class="text-muted mb-0">Total Submissions: <span class="text-white fw-bold">@(Model?.Count ?? 0)</span></p>
        </div>
    </div>

    <div class="card border-0 shadow-sm bg-secondary text-white">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0 align-middle">
                    <thead class="bg-dark text-muted small text-uppercase">
                        <tr>
                            <th class="px-4 py-3">ID</th>
                            <th class="py-3">User Email</th>
                            <th class="py-3">Document Type</th>
                            <th class="py-3">File Preview</th>
                            <th class="py-3 text-center">Status</th>
                            <th class="py-3">Submission Date</th>
                            <th class="py-3 text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null)
                        {
                            @foreach (var doc in Model)
                            {
                                <tr>
                                    <td class="px-4 py-3 text-muted">#@doc.KycId</td>
                                    <td class="py-3">
                                        <span class="fw-bold text-white">@(doc.User?.Email ?? "System User")</span>
                                        <br /><small class="text-muted">ID: @doc.UserId</small>
                                    </td>
                                    <td class="py-3"><span class="badge bg-dark border text-light">@doc.DocumentType</span></td>
                                    <td class="py-3">
                                        <a href="@doc.FilePath" target="_blank" class="btn btn-sm btn-outline-info">
                                            <i class="bi bi-eye me-1"></i> View Document
                                        </a>
                                    </td>
                                    <td class="py-3 text-center">
                                        <span class="badge rounded-pill @(doc.Status == KycStatus.Approved ? "bg-success" : doc.Status == KycStatus.Rejected ? "bg-danger" : "bg-warning text-dark")">
                                            @doc.Status
                                        </span>
                                    </td>
                                    <td class="py-3 text-muted">@doc.UploadedAt.ToString("dd MMM yyyy")</td>
                                    <td class="py-3 text-center">
                                        @if (doc.Status == KycStatus.Pending)
                                        {
                                            <form asp-action="Approve" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@doc.KycId" />
                                                <button type="submit" class="btn btn-sm btn-success px-3 me-1">
                                                    <i class="bi bi-check-lg"></i> Approve
                                                </button>
                                            </form>
                                            
                                            <button type="button" class="btn btn-sm btn-outline-danger px-3"
                                                    data-bs-toggle="modal" data-bs-target="#rejectModal"
                                                    data-id="@doc.KycId" data-user="@(doc.User?.Email ?? "this user")">
                                                <i class="bi bi-x-lg"></i> Reject
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">
                                                <i class="bi bi-check2-all me-1"></i> Processed
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-white border-0 shadow-lg">
            <div class="modal-header border-bottom border-secondary">
                <h5 class="modal-title text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Reject KYC Document</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Reject" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="id" id="modalDocId" />
                    <p class="small text-muted mb-3">Target Account: <span id="modalUserLabel" class="text-white fw-bold"></span></p>
                    <div class="mb-3">
                        <label class="form-label text-light">Reason for Rejection</label>
                        <textarea name="rejectionReason" class="form-control bg-secondary text-white border-0"
                                  rows="4" required placeholder="Please provide a reason..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-top border-secondary">
                    <button type="button" class="btn btn-link text-white text-decoration-none" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger px-4">Confirm Rejection</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var rejectModal = document.getElementById('rejectModal');
        if (rejectModal) {
            rejectModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                var id = button.getAttribute('data-id');
                var user = button.getAttribute('data-user');
                
                document.getElementById('modalDocId').value = id;
                document.getElementById('modalUserLabel').textContent = user;
            });
        }
    </script>
}
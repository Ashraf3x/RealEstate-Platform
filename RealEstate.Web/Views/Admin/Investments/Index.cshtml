@model IEnumerable<RealEstate.Application.DTOs.InvestmentDto>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Manage Investments";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title mb-1">All Investments</h1>
        <p style="color:var(--text-muted);font-size:0.85rem;margin:0">System-wide investment records</p>
    </div>
</div>

<div class="card-glass">
    <table class="table-glass">
        <thead>
            <tr>
                <th>#</th>
                <th>Investor</th>
                <th>Property</th>
                <th>Shares</th>
                <th>Ownership</th>
                <th>Date</th>
                <th style="text-align:center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="color:var(--text-muted)">@item.InvestmentId</td>
                    <td style="font-weight:600">@item.UserName</td>
                    <td>@item.PropertyName</td>
                    <td>@item.ShareCount</td>
                    <td><span class="badge-gold-glass">@item.OwnershipPercentage.ToString("0.00")%</span></td>
                    <td style="color:var(--text-muted)">@item.PurchasedAt.ToString("MMM dd, yyyy")</td>
                    <td style="text-align:center">
                        <a asp-action="Edit" asp-route-id="@item.InvestmentId"
                           class="btn-warning-glass me-1" style="text-decoration:none;border-radius:6px;padding:4px 12px;font-size:0.82rem">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.InvestmentId"
                           class="btn-danger-glass" style="text-decoration:none;border-radius:6px;padding:4px 12px;font-size:0.82rem">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
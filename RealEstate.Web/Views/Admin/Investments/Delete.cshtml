@model RealEstate.Application.DTOs.InvestmentDto
@{
    Layout = "_AdminLayout"; ViewData["Title"] = "Delete Investment";
}

<div class="d-flex justify-content-center">
    <div class="card-glass p-4 text-center" style="max-width:460px;width:100%">
        <div style="width:56px;height:56px;background:rgba(220,53,69,0.12);border:1px solid rgba(220,53,69,0.3);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.4rem;color:#ff8080">
            <i class="fas fa-trash-alt"></i>
        </div>
        <h5 style="font-family:'Rajdhani',sans-serif;font-weight:700">Delete Investment?</h5>
        <p style="color:var(--text-muted);font-size:0.85rem">This action cannot be undone.</p>
        <div style="background:rgba(255,255,255,0.04);border-radius:10px;padding:14px;text-align:left;margin-bottom:1.5rem;font-size:0.85rem">
            <div style="display:flex;justify-content:space-between;margin-bottom:5px"><span style="color:var(--text-muted)">ID</span><span>#@Model.InvestmentId</span></div>
            <div style="display:flex;justify-content:space-between;margin-bottom:5px"><span style="color:var(--text-muted)">Investor</span><span>@Model.UserName</span></div>
            <div style="display:flex;justify-content:space-between;margin-bottom:5px"><span style="color:var(--text-muted)">Property</span><span>@Model.PropertyName</span></div>
            <div style="display:flex;justify-content:space-between"><span style="color:var(--text-muted)">Shares</span><span>@Model.ShareCount</span></div>
        </div>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="InvestmentId" />
            <div class="d-flex gap-2">
                <button type="submit" style="flex:1;background:rgba(220,53,69,0.2);border:1px solid rgba(220,53,69,0.4);color:#ff8080;border-radius:8px;padding:10px;cursor:pointer;transition:all 0.2s" onmouseover="this.style.background='rgba(220,53,69,0.35)'" onmouseout="this.style.background='rgba(220,53,69,0.2)'">Delete</button>
                <a asp-action="AdminIndex" class="btn-glass flex-grow-1 text-center" style="text-decoration:none;border-radius:8px;padding:10px">Cancel</a>
            </div>
        </form>
    </div>
</div>
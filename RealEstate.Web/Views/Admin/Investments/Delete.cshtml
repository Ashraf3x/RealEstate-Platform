@model RealEstate.Application.DTOs.InvestmentDto
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Delete Investment";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm border-danger">
                <div class="card-body p-5 text-center">
                    <h4 class="fw-bold mt-3 mb-2 text-danger">Delete Investment?</h4>
                    <p class="text-muted mb-4">Are you sure you want to delete this record? This action cannot be undone.</p>

                    <div class="bg-light rounded p-3 text-start mb-4">
                        <p class="mb-1"><strong>ID:</strong> #@Model.InvestmentId</p>
                        <p class="mb-1"><strong>Investor:</strong> @Model.UserName</p>
                        <p class="mb-1"><strong>Property:</strong> @Model.PropertyName</p>
                        <p class="mb-0"><strong>Shares:</strong> @Model.ShareCount</p>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="InvestmentId" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger flex-grow-1">Yes, Delete</button>
                            <a asp-action="Index" class="btn btn-outline-secondary flex-grow-1">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
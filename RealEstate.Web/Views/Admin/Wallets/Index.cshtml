@model IEnumerable<RealEstate.Application.DTOs.WalletDto>
@{
    Layout = "_AdminLayout"; ViewData["Title"] = "All Wallets";
}

<div class="mb-4">
    <h1 class="page-title mb-1">All Wallets</h1>
    <p style="color:var(--text-muted);font-size:0.85rem;margin:0">User wallet balances</p>
</div>

<div class="card-glass">
    <table class="table-glass">
        <thead>
            <tr><th>Wallet ID</th><th>User ID</th><th>Balance</th><th>Created At</th></tr>
        </thead>
        <tbody>
            @foreach (var wallet in Model)
            {
                <tr>
                    <td style="color:var(--text-muted)">#@wallet.WalletId</td>
                    <td>@wallet.UserId</td>
                    <td><span class="badge-gold-glass">@wallet.Balance EGP</span></td>
                    <td style="color:var(--text-muted)">@wallet.CreatedAt</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@model RealEstate.Application.DTOs.CreateInvestmentDto
@{
    Layout = "_Layout"; ViewData["Title"] = "New Investment";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn-glass" style="text-decoration:none;border-radius:8px;padding:7px 14px;font-size:0.83rem">
        <i class="fas fa-arrow-left me-1"></i> Back
    </a>
    <h1 class="page-title mb-0">Invest in Property</h1>
</div>

<div class="card-glass p-4" style="max-width:480px">
    <form asp-action="Create" method="post">
        <input type="hidden" asp-for="UserId" value="1" />
        <div class="mb-3">
            <label class="form-label-glass">Select Property</label>
            <select asp-for="PropertyId" asp-items="ViewBag.Properties" class="form-select form-select-glass">
                <option value="">— Choose a Property —</option>
            </select>
            <span asp-validation-for="PropertyId" style="color:#ff8080;font-size:0.78rem"></span>
        </div>
        <div class="mb-4">
            <label class="form-label-glass">Number of Shares</label>
            <input asp-for="ShareCount" class="form-control form-control-glass" type="number" min="1" />
            <span asp-validation-for="ShareCount" style="color:#ff8080;font-size:0.78rem"></span>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn-gold flex-grow-1">Confirm Investment</button>
            <a asp-action="Index" class="btn-glass" style="text-decoration:none;border-radius:8px;padding:8px 16px">Cancel</a>
        </div>
    </form>
</div>
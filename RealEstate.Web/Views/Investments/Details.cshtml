@model RealEstate.Application.DTOs.InvestmentDto
@{
    Layout = "_Layout";
    ViewData["Title"] = "Investment Details";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5">
                    <h3 class="fw-bold mb-4 text-center">@Model.PropertyName</h3>

                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <div class="bg-light rounded p-3 text-center">
                                <p class="text-muted small mb-1">Shares</p>
                                <h5 class="fw-bold mb-0">@Model.ShareCount</h5>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="bg-light rounded p-3 text-center">
                                <p class="text-muted small mb-1">Ownership</p>
                                <h5 class="fw-bold mb-0 text-success">@Model.OwnershipPercentage.ToString("0.00")%</h5>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="bg-light rounded p-3 text-center">
                                <p class="text-muted small mb-1">Purchase Date</p>
                                <h5 class="fw-bold mb-0">@Model.PurchasedAt.ToString("dd MMM yyyy")</h5>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary w-100">Back to Portfolio</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@model RealEstate.Application.DTOs.InvestmentDto
@{
    Layout = "_Layout"; ViewData["Title"] = "Investment Details";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn-glass" style="text-decoration:none;border-radius:8px;padding:7px 14px;font-size:0.83rem">
        <i class="fas fa-arrow-left me-1"></i> Back
    </a>
    <h1 class="page-title mb-0">Investment Details</h1>
</div>

<div class="card-glass p-4" style="max-width:500px">
    <h5 style="font-family:'Rajdhani',sans-serif;font-weight:700;font-size:1.2rem;margin-bottom:1.25rem">@Model.PropertyName</h5>
    <hr class="gold-divider" />
    <div class="row g-3">
        <div class="col-6">
            <div style="background:rgba(255,255,255,0.04);border-radius:10px;padding:14px;text-align:center">
                <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:4px">Shares</div>
                <div style="font-size:1.3rem;font-weight:700;font-family:'Rajdhani',sans-serif">@Model.ShareCount</div>
            </div>
        </div>
        <div class="col-6">
            <div style="background:rgba(201,168,76,0.08);border:1px solid rgba(201,168,76,0.15);border-radius:10px;padding:14px;text-align:center">
                <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:4px">Ownership</div>
                <div style="font-size:1.3rem;font-weight:700;font-family:'Rajdhani',sans-serif;color:var(--gold-light)">@Model.OwnershipPercentage.ToString("0.00")%</div>
            </div>
        </div>
        <div class="col-12">
            <div style="background:rgba(255,255,255,0.04);border-radius:10px;padding:14px;text-align:center">
                <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:4px">Purchase Date</div>
                <div style="font-size:1rem;font-weight:600">@Model.PurchasedAt.ToString("dd MMM yyyy")</div>
            </div>
        </div>
    </div>
</div>

@model RealEstate.Application.DTOs.InvestmentDto
@{
    Layout = "_Layout";
    ViewData["Title"] = "Sell Shares";
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a asp-action="Details" asp-route-id="@Model.InvestmentId"
               class="btn btn-glass rounded-circle p-2"
               style="width:40px; height:40px; display:flex; align-items:center; justify-content:center; text-decoration:none;">
            <i class="fas fa-arrow-left text-white"></i>
        </a>
        <h1 class="h3 mb-0 fw-bold text-white">Sell Shares</h1>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card-glass p-4 border-top border-danger border-3">
                <h5 class="text-white fw-bold mb-1">@Model.PropertyName</h5>
                <p class="text-muted small mb-4">You currently own <span class="text-warning fw-bold">@Model.ShareCount shares</span></p>

                <form asp-action="SellShares" asp-route-id="@Model.InvestmentId" method="post">
                    <div class="mb-3">
                        <label class="text-muted small mb-1">Number of Shares to Sell</label>
                        <input type="number" name="sharesToSell" class="form-control bg-dark text-white border-secondary"
                               min="1" max="@Model.ShareCount" placeholder="Enter amount..." required />
                        <small class="text-muted">Max: @Model.ShareCount shares</small>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-danger w-100 fw-bold py-2">
                            <i class="fas fa-exchange-alt me-1"></i> Confirm Sell
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.InvestmentId"
                           class="btn btn-outline-secondary w-100 fw-bold py-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
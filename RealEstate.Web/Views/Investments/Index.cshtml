@model IEnumerable<RealEstate.Application.DTOs.InvestmentDto>
@{
    Layout = "_Layout";
    ViewData["Title"] = "My Portfolio";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">My Portfolio</h4>
            <p class="text-muted mb-0">Manage your property investments</p>
        </div>
        <a asp-action="Create" class="btn btn-success px-4">+ New Investment</a>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">@item.PropertyName</h5>

                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">Shares Owned</span>
                            <span class="fw-semibold">@item.ShareCount</span>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">Ownership</span>
                            <span class="fw-semibold text-success">@item.OwnershipPercentage.ToString("0.00")%</span>
                        </div>

                        <div class="d-flex justify-content-between mb-4">
                            <span class="text-muted small">Purchased</span>
                            <span class="fw-semibold">@item.PurchasedAt.ToString("MMM yyyy")</span>
                        </div>

                        <a asp-action="Details" asp-route-id="@item.InvestmentId" class="btn btn-outline-dark w-100">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
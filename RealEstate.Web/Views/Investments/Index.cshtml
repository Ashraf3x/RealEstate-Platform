@model IEnumerable<RealEstate.Application.DTOs.InvestmentDto>
@{
    Layout = "_Layout";
    ViewData["Title"] = "My Portfolio";
}

<div class="container-fluid">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="page-title mb-1" style="font-family:'Rajdhani',sans-serif; font-weight:700;">
                <i class="fas fa-chart-pie me-2 text-gold"></i>My Portfolio
            </h1>
            <p style="color:var(--text-muted);font-size:0.85rem;margin:0">Track and manage your property shares</p>
        </div>
        <a asp-action="Create" class="btn btn-warning fw-bold px-4 shadow-sm" style="text-decoration:none; border-radius:10px; padding:10px 20px">
            <i class="fas fa-plus me-1"></i> New Investment
        </a>
    </div>

    <div class="row g-3 mb-5">
        <div class="col-md-4">
            <div class="card-glass p-3 border-start border-warning border-4 text-center">
                <div class="small text-muted mb-1 text-uppercase fw-bold" style="font-size:0.65rem">Total Properties</div>
                <div class="h3 fw-bold mb-0 text-white">@Model.Count()</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card-glass p-3 border-start border-info border-4 text-center">
                <div class="small text-muted mb-1 text-uppercase fw-bold" style="font-size:0.65rem">Total Shares</div>
                <div class="h3 fw-bold mb-0 text-white">@Model.Sum(x => x.ShareCount).ToString("N0")</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card-glass p-3 border-start border-success border-4 text-center">
                <div class="small text-muted mb-1 text-uppercase fw-bold" style="font-size:0.65rem">Portfolio Yield</div>
                <div class="h3 fw-bold mb-0 text-success">+12.5%</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-12">
                <div class="card-glass p-0 overflow-hidden shadow-hover" style="transition: 0.3s transform;">
                    <div class="row g-0">
                        <div class="col-md-2 d-none d-md-flex align-items-center justify-content-center" style="background: rgba(201,168,76,0.05); min-height: 120px; border-right: 1px solid rgba(255,255,255,0.05)">
                            <i class="fas fa-building text-gold" style="font-size: 2.5rem; opacity: 0.6"></i>
                        </div>

                        <div class="col-md-10 p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h4 class="mb-1 fw-bold text-white" style="font-family:'Rajdhani',sans-serif">@item.PropertyName</h4>
                                    <span class="badge rounded-pill" style="background:rgba(201,168,76,0.1); color:var(--gold); font-size: 0.75rem; padding: 5px 12px; border: 1px solid rgba(201,168,76,0.2)">
                                        <i class="fas fa-certificate me-1"></i> Active Investment
                                    </span>
                                </div>
                                <div class="text-end">
                                    <div class="small text-muted mb-1">Ownership</div>
                                    <div class="h5 fw-bold text-gold mb-0">@item.OwnershipPercentage.ToString("0.00")%</div>
                                </div>
                            </div>

                            <div class="row align-items-center pt-2" style="border-top: 1px solid rgba(255,255,255,0.05)">
                                <div class="col-md-3">
                                    <div class="small text-muted">Shares Owned</div>
                                    <div class="fw-bold">@item.ShareCount <span class="small fw-normal text-muted">Units</span></div>
                                </div>
                                <div class="col-md-3">
                                    <div class="small text-muted">Purchase Date</div>
                                    <div class="fw-bold small">@item.PurchasedAt.ToString("MMM yyyy")</div>
                                </div>
                                <div class="col-md-4">
                                    <div class="small text-muted mb-1">Portfolio Share</div>
                                    <div class="progress" style="height: 6px; background: rgba(255,255,255,0.05); border-radius: 10px;">
                                        <div class="progress-bar bg-warning" style="width: @item.OwnershipPercentage%"></div>
                                    </div>
                                </div>
                                <div class="col-md-2 text-end">
                                    <a asp-action="Details" asp-route-id="@item.InvestmentId" class="btn btn-outline-light btn-sm rounded-pill px-4" style="border-color:rgba(255,255,255,0.2); font-size: 0.8rem">
                                        Details
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="card-glass p-5 text-center">
                    <i class="fas fa-chart-line mb-3" style="font-size:3rem; color:rgba(255,255,255,0.1)"></i>
                    <h5 class="text-white">Your portfolio is empty</h5>
                    <p class="text-muted mb-4">Start your investment journey today with PropVest</p>
                    <a asp-action="Create" class="btn btn-warning fw-bold px-5 py-2">Explore Properties</a>
                </div>
            </div>
        }
    </div>
</div>
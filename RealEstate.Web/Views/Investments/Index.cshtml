@model IEnumerable<RealEstate.Application.DTOs.InvestmentDto>
@{
    Layout = "_Layout"; ViewData["Title"] = "My Portfolio";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title mb-1"><i class="fas fa-chart-line me-2" style="font-size:1.4rem"></i>My Portfolio</h1>
        <p style="color:var(--text-muted);font-size:0.85rem;margin:0">Track your property investments</p>
    </div>
    <a asp-action="Create" class="btn-gold d-flex align-items-center gap-2" style="text-decoration:none;border-radius:8px;padding:9px 18px;font-size:0.87rem;font-weight:600">
        <i class="fas fa-plus"></i> New Investment
    </a>
</div>

<div class="row g-3">
    @foreach (var item in Model)
    {
        <div class="col-md-4">
            <div class="card-glass p-4">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
                    <div style="background:rgba(201,168,76,0.12);border:1px solid rgba(201,168,76,0.2);border-radius:8px;padding:8px 10px">
                        <i class="fas fa-building" style="color:var(--gold)"></i>
                    </div>
                    <span class="badge-gold-glass">@item.OwnershipPercentage.ToString("0.00")%</span>
                </div>
                <h5 style="font-family:'Rajdhani',sans-serif;font-size:1.05rem;font-weight:700;margin-bottom:0.75rem">@item.PropertyName</h5>
                <hr class="gold-divider" />
                <div style="display:flex;justify-content:space-between;margin-bottom:6px">
                    <span style="color:var(--text-muted);font-size:0.82rem">Shares Owned</span>
                    <span style="font-size:0.87rem;font-weight:600">@item.ShareCount</span>
                </div>
                <div style="display:flex;justify-content:space-between;margin-bottom:1rem">
                    <span style="color:var(--text-muted);font-size:0.82rem">Purchased</span>
                    <span style="font-size:0.87rem">@item.PurchasedAt.ToString("MMM yyyy")</span>
                </div>
                <a asp-action="Details" asp-route-id="@item.InvestmentId" class="btn-glass d-block text-center" style="text-decoration:none;border-radius:8px;padding:8px">
                    View Details
                </a>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="card-glass p-5 text-center">
                <i class="fas fa-chart-line" style="font-size:2.5rem;color:var(--text-muted);margin-bottom:1rem;display:block"></i>
                <p style="color:var(--text-muted)">No investments yet.</p>
                <a asp-action="Create" class="btn-gold" style="text-decoration:none;border-radius:8px;padding:9px 20px;font-size:0.87rem;font-weight:600">Start Investing</a>
            </div>
        </div>
    }
</div>
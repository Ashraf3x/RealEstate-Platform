@model List<RealEstate.Application.DTOs.PropertyDto>
@{
    Layout = "_Layout"; ViewData["Title"] = "Properties";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title mb-1"><i class="fas fa-building me-2" style="font-size:1.3rem"></i>Properties</h1>
        <p style="color:var(--text-muted);font-size:0.85rem;margin:0">Available investment properties</p>
    </div>
</div>

<div class="row g-3">
    @foreach (var item in Model)
    {
        <div class="col-md-4">
            <div class="card-glass" style="overflow:hidden">
                <img src="https://picsum.photos/seed/@item.PropertyId/400/160"
                     style="width:100%;height:160px;object-fit:cover;border-radius:14px 14px 0 0;opacity:0.75" />
                <div class="p-3">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">
                        <h6 style="font-family:'Rajdhani',sans-serif;font-weight:700;font-size:0.95rem;margin:0">@item.Title</h6>
                        @if (item.Status == "Active")
                        {
                            <span class="badge-success-glass">Active</span>
                        }
                        else
                        {
                            <span class="badge-muted-glass">@item.Status</span>
                        }
                    </div>
                    <div style="font-size:0.8rem;color:var(--text-muted);margin-bottom:0.75rem">
                        <i class="fas fa-map-marker-alt me-1"></i>@item.Location
                    </div>
                    <hr class="gold-divider" />
                    <div style="display:flex;justify-content:space-between;font-size:0.82rem;margin-bottom:0.75rem">
                        <span style="color:var(--text-muted)">Price/Share</span>
                        <span style="font-weight:700;color:var(--gold-light)">$@item.PricePerShare</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;font-size:0.82rem;margin-bottom:1rem">
                        <span style="color:var(--text-muted)">Total Shares</span>
                        <span style="font-weight:600">@item.TotalShares</span>
                    </div>
                    <a asp-action="Details" asp-route-id="@item.PropertyId"
                           class="btn-glass d-block text-center" style="text-decoration:none;border-radius:8px;padding:8px;font-size:0.83rem">
                        View Details
                    </a>
                </div>
            </div>
        </div>
    }
</div>
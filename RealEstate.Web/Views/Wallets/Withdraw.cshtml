@model RealEstate.Application.DTOs.WithdrawDto

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Withdraw";
}

<div class="bg-white rounded shadow-sm p-4">
    <h4>Withdraw</h4>
    <hr />
    <form method="post" asp-action="Withdraw">
        <input type="hidden" asp-for="WalletId" />
        <div class="mb-3">
            <label asp-for="Amount" class="form-label">Amount (EGP)</label>
            <input type="number" asp-for="Amount" class="form-control" min="0.01" step="0.01" required />
            <span asp-validation-for="Amount" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-danger">Withdraw</button>
        <a class="btn btn-secondary" asp-action="Index">Cancel</a>
    </form>
</div>
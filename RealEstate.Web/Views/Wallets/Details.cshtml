@model RealEstate.Application.DTOs.WalletDto

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Wallet Details";
}

<a asp-action="Index" style="display:inline-flex;align-items:center;gap:6px;color:var(--text-muted);font-size:0.83rem;text-decoration:none;margin-bottom:1rem;">
    <i class="fas fa-arrow-left"></i> Back to Wallet
</a>

<div class="mb-4">
    <h1 class="page-title mb-1"><i class="fas fa-wallet me-2" style="font-size:1.3rem"></i>Wallet Details</h1>
</div>

<div class="card-glass p-4" style="max-width:480px">
    <div class="row g-3 mb-3">
        <div class="col-6">
            <div style="background:rgba(255,255,255,0.04);border-radius:10px;padding:14px;">
                <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:4px;">Wallet ID</div>
                <div style="font-weight:700;font-family:'Rajdhani',sans-serif;">#@Model.WalletId</div>
            </div>
        </div>
        <div class="col-6">
            <div style="background:rgba(255,255,255,0.04);border-radius:10px;padding:14px;">
                <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:4px;">User ID</div>
                <div style="font-weight:700;font-family:'Rajdhani',sans-serif;">@Model.UserId</div>
            </div>
        </div>
        <div class="col-6">
            <div style="background:rgba(255,255,255,0.04);border-radius:10px;padding:14px;">
                <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:4px;">Balance</div>
                <div style="font-weight:700;font-family:'Rajdhani',sans-serif;color:var(--gold-light);">EGP @Model.Balance.ToString("N2")</div>
            </div>
        </div>
        <div class="col-6">
            <div style="background:rgba(255,255,255,0.04);border-radius:10px;padding:14px;">
                <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:4px;">Created At</div>
                <div style="font-weight:700;font-family:'Rajdhani',sans-serif;">@Model.CreatedAt.ToString("MMM dd, yyyy")</div>
            </div>
        </div>
    </div>

    <hr class="gold-divider" />

    <div class="d-flex gap-2 mt-3">
        <a asp-action="Deposit" asp-route-walletId="@Model.WalletId" class="btn-gold d-flex align-items-center gap-2" style="text-decoration:none;flex:1;justify-content:center;padding:9px;">
            <i class="fas fa-plus-circle"></i> Deposit
        </a>
        <a asp-action="Withdraw" asp-route-walletId="@Model.WalletId" style="background:rgba(220,53,69,0.15);border:1px solid rgba(220,53,69,0.3);color:#ff8080;border-radius:8px;padding:9px;font-size:0.87rem;font-weight:600;text-decoration:none;display:flex;align-items:center;gap:6px;flex:1;justify-content:center;">
            <i class="fas fa-minus-circle"></i> Withdraw
        </a>
        <a asp-action="GetTransactions" asp-route-walletId="@Model.WalletId" class="btn-glass d-flex align-items-center gap-2" style="text-decoration:none;flex:1;justify-content:center;padding:9px;">
            <i class="fas fa-list"></i> Transactions
        </a>
    </div>
</div>

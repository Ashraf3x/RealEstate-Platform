@model RealEstate.Application.DTOs.RegisterDto
@{
    Layout = null; ViewData["Title"] = "Register";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register — PropVest</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
            :root {
                --gold: #c9a84c;
                --gold-glow: rgba(201,168,76,0.2);
            }

            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                background: #0a0a0f;
                color: #fff;
                font-family: 'Inter',sans-serif;
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 2rem;
            }

                body::before {
                    content: '';
                    position: fixed;
                    inset: 0;
                    background: radial-gradient(ellipse at 20% 50%, rgba(201,168,76,0.06), transparent 55%);
                    pointer-events: none;
                }

            .register-box {
                width: 100%;
                max-width: 520px;
                position: relative;
                z-index: 1;
            }

            .brand {
                font-family: 'Rajdhani',sans-serif;
                font-size: 1.8rem;
                font-weight: 700;
                color: var(--gold);
                letter-spacing: 2px;
                display: flex;
                align-items: center;
                gap: 10px;
                margin-bottom: 0.4rem;
            }

            .card-glass {
                background: rgba(255,255,255,0.04);
                border: 1px solid rgba(255,255,255,0.08);
                border-radius: 16px;
                padding: 2rem;
            }

            .form-field {
                margin-bottom: 1rem;
            }

                .form-field label {
                    display: block;
                    font-size: 0.82rem;
                    color: rgba(255,255,255,0.5);
                    margin-bottom: 5px;
                }

                .form-field input {
                    width: 100%;
                    background: rgba(255,255,255,0.06);
                    border: 1px solid rgba(255,255,255,0.1);
                    border-radius: 8px;
                    padding: 11px 14px;
                    color: #fff;
                    font-size: 0.9rem;
                    outline: none;
                    transition: border-color 0.2s, box-shadow 0.2s;
                }

                    .form-field input:focus {
                        border-color: var(--gold);
                        box-shadow: 0 0 0 3px var(--gold-glow);
                    }

                    .form-field input::placeholder {
                        color: rgba(255,255,255,0.25);
                    }

            .btn-register {
                width: 100%;
                background: linear-gradient(135deg,var(--gold),#a8833a);
                border: none;
                color: #000;
                font-weight: 700;
                border-radius: 8px;
                padding: 13px;
                font-size: 0.95rem;
                cursor: pointer;
                transition: all 0.2s;
                margin-top: 0.5rem;
            }

                .btn-register:hover {
                    transform: translateY(-1px);
                    box-shadow: 0 6px 20px var(--gold-glow);
                }

            .validation-msg {
                background: rgba(220,53,69,0.12);
                border: 1px solid rgba(220,53,69,0.3);
                color: #ff8080;
                border-radius: 8px;
                padding: 10px 14px;
                font-size: 0.82rem;
                margin-bottom: 1rem;
            }

            .divider {
                height: 1px;
                background: linear-gradient(90deg,transparent,rgba(255,255,255,0.1),transparent);
                margin: 1.5rem 0;
            }
    </style>
</head>
<body>
    <div class="register-box">
        <div class="brand mb-2">
            <i class="fas fa-building" style="font-size:1.4rem"></i> PropVest
        </div>
        <p style="color:rgba(255,255,255,0.4);font-size:0.85rem;margin-bottom:1.5rem">Create your investment account</p>

        <div class="card-glass">
            <form asp-action="Register" asp-controller="Account" method="post">
                @if (ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="validation-msg">
                        <i class="fas fa-exclamation-circle me-1"></i>
                        <span asp-validation-summary="ModelOnly"></span>
                    </div>
                }
                <div class="row g-3 mb-1">
                    <div class="col-6">
                        <div class="form-field mb-0">
                            <label>First Name</label>
                            <input asp-for="FirstName" placeholder="Ahmed" />
                            <span asp-validation-for="FirstName" style="color:#ff8080;font-size:0.78rem"></span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="form-field mb-0">
                            <label>Last Name</label>
                            <input asp-for="LastName" placeholder="Mohamed" />
                            <span asp-validation-for="LastName" style="color:#ff8080;font-size:0.78rem"></span>
                        </div>
                    </div>
                </div>
                <div class="form-field mt-3">
                    <label>Username</label>
                    <input asp-for="UserName" placeholder="Choose a username" />
                    <span asp-validation-for="UserName" style="color:#ff8080;font-size:0.78rem"></span>
                </div>
                <div class="form-field">
                    <label>Email</label>
                    <input asp-for="Email" placeholder="example@email.com" />
                    <span asp-validation-for="Email" style="color:#ff8080;font-size:0.78rem"></span>
                </div>
                <div class="form-field">
                    <label>Password</label>
                    <input asp-for="Password" type="password" placeholder="Min 8 characters" />
                    <span asp-validation-for="Password" style="color:#ff8080;font-size:0.78rem"></span>
                </div>
                <div class="form-field">
                    <label>Confirm Password</label>
                    <input asp-for="ConfirmPassword" type="password" placeholder="Repeat password" />
                    <span asp-validation-for="ConfirmPassword" style="color:#ff8080;font-size:0.78rem"></span>
                </div>
                <button type="submit" class="btn-register">Create Account</button>
            </form>
        </div>

        <div class="divider"></div>
        <p style="text-align:center;font-size:0.83rem;color:rgba(255,255,255,0.4)">
            Already have an account?
            <a asp-action="Login" asp-controller="Account" style="color:var(--gold);text-decoration:none;font-weight:600">Sign in</a>
        </p>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
@model RealEstate.Application.DTOs.LoginDto
@{
    Layout = null; ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — PropVest</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
            :root {
                --gold: #c9a84c;
                --gold-glow: rgba(201,168,76,0.2);
            }

            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                background: #0a0a0f;
                color: #fff;
                font-family: 'Inter',sans-serif;
                min-height: 100vh;
                display: flex;
            }

                body::before {
                    content: '';
                    position: fixed;
                    inset: 0;
                    background: radial-gradient(ellipse at 20% 50%, rgba(201,168,76,0.06), transparent 55%), radial-gradient(ellipse at 80% 20%, rgba(201,168,76,0.04), transparent 50%);
                    pointer-events: none;
                }

            .left-panel {
                flex: 1;
                position: relative;
                overflow: hidden;
            }

                .left-panel img {
                    width: 100%;
                    height: 100vh;
                    object-fit: cover;
                    opacity: 0.5;
                }

                .left-panel::after {
                    content: '';
                    position: absolute;
                    inset: 0;
                    background: linear-gradient(90deg, transparent 60%, #0a0a0f);
                }

            .left-overlay {
                position: absolute;
                bottom: 3rem;
                left: 3rem;
                z-index: 1;
            }

                .left-overlay h2 {
                    font-family: 'Rajdhani',sans-serif;
                    font-size: 2.5rem;
                    font-weight: 700;
                    color: var(--gold);
                    margin: 0;
                }

                .left-overlay p {
                    color: rgba(255,255,255,0.6);
                    font-size: 0.95rem;
                    margin: 0;
                }

            .right-panel {
                width: 440px;
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 2rem;
                background: rgba(0,0,0,0.5);
                backdrop-filter: blur(20px);
                border-left: 1px solid rgba(255,255,255,0.06);
                position: relative;
                z-index: 1;
            }

            .login-box {
                width: 100%;
            }

            .brand {
                font-family: 'Rajdhani',sans-serif;
                font-size: 1.8rem;
                font-weight: 700;
                color: var(--gold);
                letter-spacing: 2px;
                display: flex;
                align-items: center;
                gap: 10px;
                margin-bottom: 0.4rem;
            }

            .form-field {
                margin-bottom: 1rem;
            }

                .form-field label {
                    display: block;
                    font-size: 0.82rem;
                    color: rgba(255,255,255,0.5);
                    margin-bottom: 5px;
                }

                .form-field input {
                    width: 100%;
                    background: rgba(255,255,255,0.06);
                    border: 1px solid rgba(255,255,255,0.1);
                    border-radius: 8px;
                    padding: 11px 14px;
                    color: #fff;
                    font-size: 0.9rem;
                    outline: none;
                    transition: border-color 0.2s, box-shadow 0.2s;
                }

                    .form-field input:focus {
                        border-color: var(--gold);
                        box-shadow: 0 0 0 3px var(--gold-glow);
                    }

                    .form-field input::placeholder {
                        color: rgba(255,255,255,0.25);
                    }

            .btn-login {
                width: 100%;
                background: linear-gradient(135deg,var(--gold),#a8833a);
                border: none;
                color: #000;
                font-weight: 700;
                border-radius: 8px;
                padding: 13px;
                font-size: 0.95rem;
                cursor: pointer;
                transition: all 0.2s;
                margin-top: 0.5rem;
            }

                .btn-login:hover {
                    transform: translateY(-1px);
                    box-shadow: 0 6px 20px var(--gold-glow);
                }

            .divider {
                height: 1px;
                background: linear-gradient(90deg,transparent,rgba(255,255,255,0.1),transparent);
                margin: 1.5rem 0;
            }

            .validation-msg {
                background: rgba(220,53,69,0.12);
                border: 1px solid rgba(220,53,69,0.3);
                color: #ff8080;
                border-radius: 8px;
                padding: 10px 14px;
                font-size: 0.82rem;
                margin-bottom: 1rem;
            }

            @@media (max-width:768px) {
                .left-panel {
                    display: none;
                }

                .right-panel {
                    width: 100%;
                }
            }
    </style>
</head>
<body>
    <div class="left-panel d-none d-md-block">
        <img src="https://images.unsplash.com/photo-1486325212027-8081e485255e?w=1200&q=80" alt="Real Estate" />
        <div class="left-overlay">
            <h2>PropVest</h2>
            <p>Invest smarter. Build wealth through property.</p>
        </div>
    </div>

    <div class="right-panel">
        <div class="login-box">
            <div class="brand">
                <i class="fas fa-building" style="font-size:1.4rem"></i> PropVest
            </div>
            <p style="color:rgba(255,255,255,0.4);font-size:0.85rem;margin-bottom:2rem">Welcome back — sign in to your account</p>

            <form asp-action="Login" asp-controller="Account" method="post">
                @if (ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="validation-msg">
                        <i class="fas fa-exclamation-circle me-1"></i>
                        <span asp-validation-summary="ModelOnly"></span>
                    </div>
                }

                <div class="form-field">
                    <label>Username</label>
                    <input asp-for="UserName" placeholder="Enter your username" autocomplete="username" />
                    <span asp-validation-for="UserName" style="color:#ff8080;font-size:0.78rem"></span>
                </div>

                <div class="form-field">
                    <label>Password</label>
                    <input asp-for="Password" type="password" placeholder="Enter your password" autocomplete="current-password" />
                    <span asp-validation-for="Password" style="color:#ff8080;font-size:0.78rem"></span>
                </div>

                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.2rem">
                    <label style="display:flex;align-items:center;gap:7px;font-size:0.82rem;color:rgba(255,255,255,0.5);cursor:pointer">
                        <input asp-for="RememberMe" type="checkbox" style="accent-color:var(--gold)" /> Remember me
                    </label>
                    <a href="#" style="font-size:0.82rem;color:rgba(201,168,76,0.7);text-decoration:none">Forgot password?</a>
                </div>

                <div style="margin-bottom:1.2rem">
                    <label style="font-size:0.82rem;color:rgba(255,255,255,0.5);display:block;margin-bottom:8px">Login as</label>
                    <div style="display:flex;gap:8px">
                        <label style="flex:1;cursor:pointer">
                            <input type="radio" asp-for="Role" value="User" style="display:none" class="role-radio" />
                            <div class="role-btn" id="btn-user" style="text-align:center;padding:10px;border-radius:8px;border:1px solid rgba(201,168,76,0.5);background:rgba(201,168,76,0.15);color:var(--gold);font-size:0.85rem;font-weight:600;transition:all 0.2s">
                                <i class="fas fa-user me-1"></i> User
                            </div>
                        </label>
                        <label style="flex:1;cursor:pointer">
                            <input type="radio" asp-for="Role" value="Admin" style="display:none" class="role-radio" />
                            <div class="role-btn" id="btn-admin" style="text-align:center;padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.04);color:rgba(255,255,255,0.5);font-size:0.85rem;font-weight:600;transition:all 0.2s">
                                <i class="fas fa-shield-alt me-1"></i> Admin
                            </div>
                        </label>
                    </div>
                </div>

                <button type="submit" class="btn-login">Sign In</button>
            </form>

            <div class="divider"></div>
            <p style="text-align:center;font-size:0.83rem;color:rgba(255,255,255,0.4)">
                Don't have an account?
                <a asp-action="Register" asp-controller="Account" style="color:var(--gold);text-decoration:none;font-weight:600">Register now</a>
            </p>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const radios = document.querySelectorAll('.role-radio');
        const btnUser = document.getElementById('btn-user');
        const btnAdmin = document.getElementById('btn-admin');

        const activeStyle = 'text-align:center;padding:10px;border-radius:8px;border:1px solid rgba(201,168,76,0.5);background:rgba(201,168,76,0.15);color:#c9a84c;font-size:0.85rem;font-weight:600;transition:all 0.2s';
        const inactiveStyle = 'text-align:center;padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.04);color:rgba(255,255,255,0.5);font-size:0.85rem;font-weight:600;transition:all 0.2s';

        radios[0].checked = true;

        radios.forEach(r => r.addEventListener('change', function () {
        if (this.value === 'User') {
        btnUser.style.cssText = activeStyle;
        btnAdmin.style.cssText = inactiveStyle;
        } else {
        btnAdmin.style.cssText = activeStyle;
        btnUser.style.cssText = inactiveStyle;
        }
        }));
    </script>
</body>
</html>

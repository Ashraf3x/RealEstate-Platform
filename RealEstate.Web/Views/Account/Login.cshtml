@model RealEstate.Application.DTOs.LoginDto
@{
    Layout = null;
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - PropVest</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="bg-white">
    <div class="container-fluid p-0">
        <div class="row g-0 min-vh-100">

            <div class="col-md-6 d-none d-md-block">
                <img src="https://loremflickr.com/800/1200/realestate,architecture,house?random=@Guid.NewGuid()"
                     style="width:100%; height:100vh; object-fit:cover;" />
            </div>

            <div class="col-md-6 d-flex align-items-center justify-content-center">
                <div style="width: 100%; max-width: 400px; padding: 20px;">

                    <div class="text-center mb-4">
                        <h2 class="fw-bold">PropVest</h2>
                        <p class="text-muted">Welcome back! Please login to your account.</p>
                    </div>

                    <form asp-action="Login" asp-controller="Account" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>

                        <div class="mb-3">
                            <label asp-for="UserName" class="form-label fw-semibold">Username</label>
                            <input asp-for="UserName" class="form-control form-control-lg fs-6" placeholder="Enter your username" />
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-semibold">Password</label>
                            <input asp-for="Password" type="password" class="form-control form-control-lg fs-6" placeholder="Enter your password" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-4 d-flex justify-content-between align-items-center">
                            <div class="form-check">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label asp-for="RememberMe" class="form-check-label text-muted small">Remember me</label>
                            </div>
                            <a href="#" class="text-decoration-none small text-dark">Forgot password?</a>
                        </div>

                        <button type="submit" class="btn btn-dark w-100 py-3 fw-bold">Sign In</button>
                    </form>

                    <p class="text-center mt-4 text-muted small">
                        Don't have an account?
                        <a asp-action="Register" asp-controller="Account" class="text-dark fw-bold text-decoration-none">Register now</a>
                    </p>
                </div>
            </div>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
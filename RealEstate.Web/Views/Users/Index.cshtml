@model List<RealEstate.Application.DTOs.UserDto>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "User Management";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title mb-1">Users</h1>
        <p style="color:var(--text-muted);font-size:0.85rem;margin:0">@Model.Count total users</p>
    </div>
</div>

<div class="card-glass">
    <table class="table-glass">
        <thead>
            <tr>
                <th>#</th>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="color:var(--text-muted)">@item.UserId</td>
                    <td style="font-weight:600">@item.FirstName @item.LastName</td>
                    <td style="color:var(--text-muted)">@item.Email</td>
                    <td>
                        @if (item.Role == "Admin")
                        {
                            <span class="badge-gold-glass">@item.Role</span>
                        }
                        else
                        {
                            <span class="badge-muted-glass">@item.Role</span>
                        }
                    </td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span class="badge-success-glass">Active</span>
                        }
                        else
                        {
                            <span class="badge-danger-glass">Inactive</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.UserId"
                           class="btn-glass me-1" style="text-decoration:none;border-radius:6px;padding:4px 12px;font-size:0.82rem">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.UserId"
                           class="btn-danger-glass" style="text-decoration:none;border-radius:6px;padding:4px 12px;font-size:0.82rem">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
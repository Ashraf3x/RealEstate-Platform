@model RealEstate.Application.DTOs.DashboardDto

@{
    Layout = User.IsInRole("Admin") ? "~/Views/Shared/_AdminLayout.cshtml" : "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<style>
    .dash {
        font-family: inherit;
    }

    .page-title {
        font-size: 1.4rem;
        font-weight: 500;
        margin-bottom: 1.5rem;
    }

    .stat-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0,1fr));
        gap: 12px;
        margin-bottom: 1.25rem;
    }

    .stat-card {
        background: #1c1c1c;
        border-radius: 10px;
        padding: 1rem 1.25rem;
        border: 0.5px solid #2e2e2e;
    }

    .stat-label {
        font-size: 11px;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 6px;
    }

    .stat-val {
        font-size: 1.5rem;
        font-weight: 500;
        color: #e0e0e0;
    }

    .stat-sub {
        font-size: 11px;
        margin-top: 4px;
        color: #c9a84c;
    }

    .two-col {
        display: grid;
        grid-template-columns: minmax(0,1.4fr) minmax(0,1fr);
        gap: 12px;
        margin-bottom: 1.25rem;
    }

    .panel {
        background: #1c1c1c;
        border: 0.5px solid #2e2e2e;
        border-radius: 10px;
        padding: 1rem 1.25rem;
    }

    .panel-title {
        font-size: 11px;
        font-weight: 500;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 10px;
    }

    .t-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 0.5px solid #2a2a2a;
        font-size: 13px;
    }

        .t-row:last-child {
            border-bottom: none;
        }

    .t-name {
        color: #ddd;
        font-size: 13px;
    }

    .t-sub {
        color: #666;
        font-size: 11px;
        margin-top: 1px;
    }

    .badge {
        font-size: 11px;
        padding: 2px 10px;
        border-radius: 99px;
    }

    .badge-active {
        background: #1a3a1a;
        color: #4caf50;
    }

    .badge-inactive {
        background: #3a1a1a;
        color: #e57373;
    }

    .dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .dot-g {
        background: #4caf50;
    }

    .dot-r {
        background: #e57373;
    }

    .tx-pos {
        color: #4caf50;
        font-size: 13px;
    }

    .tx-neg {
        color: #e57373;
        font-size: 13px;
    }

    .action-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0,1fr));
        gap: 10px;
        margin-bottom: 1.25rem;
    }

    .action-card {
        background: #1c1c1c;
        border: 0.5px solid #2e2e2e;
        border-radius: 10px;
        padding: 1rem;
        text-align: center;
        text-decoration: none;
        display: block;
        transition: border-color 0.2s;
    }

        .action-card:hover {
            border-color: #c9a84c;
            text-decoration: none;
        }

    .action-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        margin: 0 auto 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .action-label {
        font-size: 12px;
        color: #aaa;
    }

    .wallet-card {
        background: linear-gradient(135deg, #2d2d3a 0%, #4a4a5e 60%, #6b6b85 100%);
        border-radius: 16px;
        padding: 1.5rem;
        color: white;
        position: relative;
        overflow: hidden;
    }

        .wallet-card::before {
            content: '';
            position: absolute;
            top: -30px;
            right: -30px;
            width: 120px;
            height: 120px;
            background: rgba(255,255,255,0.05);
            border-radius: 50%;
        }

    .wc-brand {
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 1px;
        opacity: 0.9;
        margin-bottom: 1rem;
    }

    .wc-label {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        opacity: 0.6;
    }

    .wc-balance {
        font-size: 1.75rem;
        font-weight: 500;
        margin: 4px 0 1rem;
        letter-spacing: -0.5px;
    }

    .wc-holder {
        font-size: 0.85rem;
        font-weight: 600;
        margin-top: 2px;
        margin-bottom: 1.25rem;
    }

    .wc-btn {
        flex: 1;
        text-align: center;
        background: rgba(255,255,255,0.15);
        color: white;
        border-radius: 8px;
        padding: 8px;
        font-size: 13px;
        text-decoration: none;
    }

        .wc-btn:hover {
            background: rgba(255,255,255,0.25);
            color: white;
            text-decoration: none;
        }

    .wc-btn-outline {
        flex: 1;
        text-align: center;
        background: rgba(255,255,255,0.08);
        color: white;
        border-radius: 8px;
        padding: 8px;
        font-size: 13px;
        text-decoration: none;
    }

        .wc-btn-outline:hover {
            background: rgba(255,255,255,0.18);
            color: white;
            text-decoration: none;
        }

    .prop-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0,1fr));
        gap: 12px;
        margin-bottom: 1.25rem;
    }

    .prop-card {
        background: #1c1c1c;
        border: 0.5px solid #2e2e2e;
        border-radius: 10px;
        overflow: hidden;
        text-decoration: none;
        display: block;
        transition: border-color 0.2s;
    }

        .prop-card:hover {
            border-color: #c9a84c;
            text-decoration: none;
        }

    .prop-img {
        height: 100px;
        background: #2a2a2a;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .prop-body {
        padding: 0.75rem 1rem;
    }

    .prop-title {
        font-size: 13px;
        color: #ddd;
        font-weight: 500;
        margin-bottom: 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .prop-loc {
        font-size: 11px;
        color: #666;
    }

    .prop-price {
        font-size: 12px;
        color: #c9a84c;
        margin-top: 4px;
    }

    .empty-msg {
        color: #666;
        font-size: 13px;
        padding: 1rem 0;
    }

    @@media (max-width: 768px) {
        .stat-grid {
            grid-template-columns: repeat(2, minmax(0,1fr));
        }

        .two-col {
            grid-template-columns: 1fr;
        }

        .action-grid {
            grid-template-columns: repeat(2, minmax(0,1fr));
        }

        .prop-grid {
            grid-template-columns: repeat(2, minmax(0,1fr));
        }
    }
</style>

<div class="dash">

    @if (User.IsInRole("Admin"))
    {
        <div class="page-title">Admin Dashboard</div>

        <div class="stat-grid">
            <div class="stat-card">
                <div class="stat-label">Total Users</div>
                <div class="stat-val">@Model.TotalUsers</div>
                <div class="stat-sub">registered accounts</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Properties</div>
                <div class="stat-val">@Model.TotalProperties</div>
                <div class="stat-sub">on platform</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Total Investments</div>
                <div class="stat-val">EGP @Model.TotalPlatformInvestments.ToString("N0")</div>
                <div class="stat-sub">across all users</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Platform Balance</div>
                <div class="stat-val">EGP @Model.TotalPlatformBalance.ToString("N0")</div>
                <div class="stat-sub">across all wallets</div>
            </div>
        </div>

        <div class="two-col">
            <div class="panel">
                <div class="panel-title">Recent Users</div>
                @if (Model.RecentUsers.Any())
                {
                    foreach (var u in Model.RecentUsers)
                    {
                        <div class="t-row">
                            <div>
                                <div class="t-name">@u.FirstName @u.LastName</div>
                                <div class="t-sub">@u.Email</div>
                            </div>
                            <span class="badge @(u.IsActive ? "badge-active" : "badge-inactive")">
                                @(u.IsActive ? "Active" : "Inactive")
                            </span>
                        </div>
                    }
                }
                else
                {

                    <div class="empty-msg">No users yet</div>
                }
            </div>

            <div class="panel">
                <div class="panel-title">Recent Transactions</div>
                @if (Model.RecentPlatformTransactions.Any())
                {
                    foreach (var t in Model.RecentPlatformTransactions)
                    {
                        var isDeposit = t.Type == "Deposit";
                        <div class="t-row">
                            <div style="display:flex;align-items:center;gap:8px;">
                                <div class="dot @(isDeposit ? "dot-g" : "dot-r")"></div>
                                <div>
                                    <div class="t-name">@t.Type</div>
                                    <div class="t-sub">@t.Timestamp.ToString("MMM dd, yyyy")</div>
                                </div>
                            </div>
                            <div class="@(isDeposit ? "tx-pos" : "tx-neg")">
                                @(isDeposit ? "+" : "-")EGP @t.Amount.ToString("N0")
                            </div>
                        </div>
                    }
                }
                else
                {

                    <div class="empty-msg">No transactions yet</div>
                }
            </div>
        </div>

        <div class="panel-title">Quick Actions</div>
        <div class="action-grid">
            <a class="action-card" asp-controller="Users" asp-action="Index">
                <div class="action-icon" style="background:#1e2e1e;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4caf50" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /></svg>
                </div>
                <div class="action-label">Manage Users</div>
            </a>
            <a class="action-card" asp-controller="Properties" asp-action="AdminIndex">
                <div class="action-icon" style="background:#2e2a1a;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" /><path d="M3 9h18M9 21V9" /></svg>
                </div>
                <div class="action-label">Properties</div>
            </a>
            <a class="action-card" asp-controller="Wallets" asp-action="GetAllWallets">
                <div class="action-icon" style="background:#1a1e2e;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#5b9bd5" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" /></svg>
                </div>
                <div class="action-label">Financials</div>
            </a>
            <a class="action-card" href="#">
                <div class="action-icon" style="background:#2e1a1a;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#e57373" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                </div>
                <div class="action-label">KYC Documents</div>
            </a>
        </div>
    }
    else
    {
        <div class="page-title">Dashboard</div>

        <div class="stat-grid">
            <div class="stat-card">
                <div class="stat-label">Wallet Balance</div>
                <div class="stat-val">EGP @Model.WalletBalance.ToString("N0")</div>
                <div class="stat-sub">available funds</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Total Invested</div>
                <div class="stat-val">EGP @Model.TotalInvested.ToString("N0")</div>
                <div class="stat-sub">across properties</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Active Investments</div>
                <div class="stat-val">@Model.ActiveInvestmentsCount</div>
                <div class="stat-sub">properties</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Recent Activity</div>
                <div class="stat-val">@Model.RecentTransactions.Count</div>
                <div class="stat-sub">transactions</div>
            </div>
        </div>

        <div class="two-col">
            <div class="wallet-card">
                <div class="wc-brand">PropVest</div>
                <div class="wc-label">Balance</div>
                <div class="wc-balance">EGP @Model.WalletBalance.ToString("N2")</div>
                <div class="wc-label">Card Holder</div>
                <div class="wc-holder">@User.Identity?.Name</div>
                <div style="display:flex;gap:10px;">
                    <a class="wc-btn" asp-controller="Wallets" asp-action="Deposit" asp-route-walletId="@Model.WalletId">Deposit</a>
                    <a class="wc-btn-outline" asp-controller="Wallets" asp-action="Withdraw" asp-route-walletId="@Model.WalletId">Withdraw</a>
                </div>
            </div>

            <div class="panel">
                <div class="panel-title">Recent Transactions</div>
                @if (Model.RecentTransactions.Any())
                {
                    foreach (var t in Model.RecentTransactions)
                    {
                        var isDeposit = t.Type == "Deposit";
                        <div class="t-row">
                            <div style="display:flex;align-items:center;gap:8px;">
                                <div class="dot @(isDeposit ? "dot-g" : "dot-r")"></div>
                                <div>
                                    <div class="t-name">@t.Type</div>
                                    <div class="t-sub">@t.Timestamp.ToString("MMM dd")</div>
                                </div>
                            </div>
                            <div class="@(isDeposit ? "tx-pos" : "tx-neg")">
                                @(isDeposit ? "+" : "-")EGP @t.Amount.ToString("N0")
                            </div>
                        </div>
                    }
                }
                else
                {

                    <div class="empty-msg">No transactions yet</div>
                }
            </div>
        </div>

        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
            <div class="panel-title" style="margin-bottom:0;">New Properties</div>
            <a asp-controller="Properties" asp-action="Index" style="font-size:12px;color:#c9a84c;text-decoration:none;">Explore More →</a>
        </div>
        <div class="prop-grid">
            @if (Model.NewProperties.Any())
            {
                foreach (var p in Model.NewProperties)
                {
                    <a class="prop-card" asp-controller="Properties" asp-action="Details" asp-route-id="@p.PropertyId">
                        <div class="prop-img">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" /><path d="M3 9h18M9 21V9" /></svg>
                        </div>
                        <div class="prop-body">
                            <div class="prop-title">@p.Title</div>
                            <div class="prop-loc">@p.Location</div>
                            <div class="prop-price">EGP @p.PricePerShare.ToString("N0") / share</div>
                        </div>
                    </a>
                }
            }
            else
            {

                <div class="empty-msg" style="grid-column:1/-1;">No properties available yet</div>
            }
        </div>
    }

</div>

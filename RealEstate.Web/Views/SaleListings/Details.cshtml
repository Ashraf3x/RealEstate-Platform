@model RealEstate.Application.DTOs.SaleListingDto
@{
    Layout = "_Layout";
    ViewData["Title"] = "Listing Details";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="fw-bold mb-0">@Model.PropertyTitle</h3>
                        <span class="badge @(Model.Status == "Active" ? "bg-success" : "bg-secondary") fs-6">
                            @Model.Status
                        </span>
                    </div>
                    <hr />
                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <div class="bg-light rounded p-3 text-center">
                                <p class="text-muted small mb-1">Price Per Share</p>
                                <h5 class="fw-bold mb-0">$@Model.PricePerShare</h5>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="bg-light rounded p-3 text-center">
                                <p class="text-muted small mb-1">Available Shares</p>
                                <h5 class="fw-bold mb-0">@Model.Quantity</h5>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-controller="Investments"
                           asp-action="ConfirmInvestment"
                           asp-route-propertyId="@Model.PropertyId"
                           asp-route-shares="@Model.Quantity"
                           class="btn btn-success flex-grow-1">Invest Now</a>
                           <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
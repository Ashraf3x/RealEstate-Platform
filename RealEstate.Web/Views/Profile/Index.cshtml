@model RealEstate.Application.DTOs.UserDto
@{
    Layout = "_Layout";
    ViewData["Title"] = "Profile";
}

<div class="container-fluid">
    <div class="mb-4">
        <h1 class="page-title mb-1"><i class="fas fa-user-circle me-2" style="font-size:1.3rem"></i>My Profile</h1>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card-glass p-4 h-100">
                <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem">
                    <div style="width:75px;height:75px;background:rgba(201,168,76,0.1);border:2px solid var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.8rem;color:var(--gold);overflow:hidden">
                        @if (!string.IsNullOrEmpty(Model.ProfilePicturePath))
                        {
                            <img src="@Model.ProfilePicturePath" style="width:100%;height:100%;object-fit:cover" />
                        }
                        else
                        {
                            <i class="fas fa-user"></i>
                        }
                    </div>
                    <div>
                        <h4 style="font-family:'Rajdhani',sans-serif;font-weight:700;margin:0">@Model.FirstName @Model.LastName</h4>
                        <div style="font-size:0.83rem;color:var(--text-muted)">@Model.Email</div>
                    </div>
                    <div class="ms-auto">
                        @if (Model.IsVerified)
                        {
                            <span class="text-success small fw-bold"><i class="fas fa-check-double"></i> Verified</span>
                        }
                    </div>
                </div>

                <hr class="gold-divider" />

                <div class="row g-3 mt-1 text-center">
                    <div class="col-6">
                        <div class="p-3 rounded-3" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.05)">
                            <div class="small text-muted mb-1">Role</div>
                            <div class="fw-bold text-gold">@Model.Role</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 rounded-3" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.05)">
                            <div class="small text-muted mb-1">Joined</div>
                            <div class="fw-bold">@Model.CreatedAt.ToString("MMM yyyy")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card-glass p-4">
                <h6 class="text-muted small mb-4">EDIT ACCOUNT DETAILS</h6>
                <form asp-action="UpdateProfile" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="UserId" />
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small text-muted">First Name</label>
                            <input type="text" asp-for="FirstName" class="form-control bg-dark text-white border-secondary shadow-none">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small text-muted">Last Name</label>
                                <input type="text" asp-for="LastName" class="form-control bg-dark text-white border-secondary shadow-none">
                                </div>
                                <div class="col-12">
                                    <label class="form-label small text-muted">Phone Number</label>
                                    <input type="text" asp-for="PhoneNumber" class="form-control bg-dark text-white border-secondary shadow-none">
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label small text-muted">Change Profile Picture</label>
                                        <input type="file" asp-for="ProfilePicture" class="form-control bg-dark text-white border-secondary shadow-none" accept="image/*">
                                        </div>
                                        <div class="col-12 mt-4">
                                            <button type="submit" class="btn btn-warning btn-sm px-4 fw-bold">Save Changes</button>
                                            <a asp-action="ChangePassword" class="btn btn-outline-light btn-sm px-4 ms-2">Change Password</a>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
@model RealEstate.Application.DTOs.UserDto
@{
    Layout = "_Layout"; ViewData["Title"] = "Profile";
}

<div class="mb-4">
    <h1 class="page-title mb-1"><i class="fas fa-user-circle me-2" style="font-size:1.3rem"></i>My Profile</h1>
</div>

<div class="card-glass p-4" style="max-width:560px">
    <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem">
        <div style="width:60px;height:60px;background:rgba(201,168,76,0.12);border:2px solid rgba(201,168,76,0.3);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.5rem;color:var(--gold)">
            <i class="fas fa-user"></i>
        </div>
        <div>
            <h5 style="font-family:'Rajdhani',sans-serif;font-weight:700;margin:0">@Model.FirstName @Model.LastName</h5>
            <div style="font-size:0.83rem;color:var(--text-muted)">@Model.Email</div>
        </div>
        <span class="badge-success-glass ms-auto">Active</span>
    </div>
    <hr class="gold-divider" />
    <div class="row g-3 mt-1">
        <div class="col-6">
            <div style="background:rgba(255,255,255,0.04);border-radius:10px;padding:14px;text-align:center">
                <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:4px">Role</div>
                <div style="font-weight:700;font-family:'Rajdhani',sans-serif">@Model.Role</div>
            </div>
        </div>
        <div class="col-6">
            <div style="background:rgba(255,255,255,0.04);border-radius:10px;padding:14px;text-align:center">
                <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:4px">Member Since</div>
                <div style="font-weight:700;font-family:'Rajdhani',sans-serif">@Model.CreatedAt.ToString("MMM yyyy")</div>
            </div>
        </div>
    </div>
</div>

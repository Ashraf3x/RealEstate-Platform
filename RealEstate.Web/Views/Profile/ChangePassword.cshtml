@model RealEstate.Application.DTOs.ChangePasswordViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Change Password";
}

<div class="container-fluid">
    <div class="mb-4">
        <h1 class="page-title mb-1">
            <a asp-action="Index" class="text-decoration-none text-white me-2">
                <i class="fas fa-arrow-left" style="font-size:1rem"></i>
            </a>
            Change Password
        </h1>
    </div>

    <div class="card-glass p-4" style="max-width: 500px;">
        <form asp-action="ChangePassword" method="post">
            <div asp-validation-summary="All" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label class="form-label small text-muted">Current Password</label>
                <input type="password" name="CurrentPassword" class="form-control bg-dark text-white border-secondary shadow-none" required>
            </div>

            <div class="mb-3">
                <label class="form-label small text-muted">New Password</label>
                <input type="password" name="NewPassword" class="form-control bg-dark text-white border-secondary shadow-none" required>
            </div>

            <div class="mb-4">
                <label class="form-label small text-muted">Confirm New Password</label>
                <input type="password" name="ConfirmPassword" class="form-control bg-dark text-white border-secondary shadow-none" required>
            </div>

            <button type="submit" class="btn btn-outline-light w-100 shadow-none">Update Password</button>
        </form>
    </div>
</div>
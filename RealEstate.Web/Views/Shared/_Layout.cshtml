<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PropVest</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RealEstate.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
</head>
<body>
    <div class="container-fluid p-3">

        <!-- Top Header -->
        <div class="d-flex justify-content-between align-items-center mb-3 p-3 bg-white rounded shadow-sm">
            <a class="text-dark text-decoration-none fw-bold fs-5" asp-controller="Home" asp-action="Index">
                PropVest
            </a>
            <div class="d-flex align-items-center gap-3">
                <button class="btn d-md-none border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mobileSidebar">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5z" />
                    </svg>
                </button>
            </div>
        </div>

        <!-- Mobile Sidebar Dropdown -->
        <div class="collapse d-md-none mb-3 bg-white rounded shadow-sm p-3" id="mobileSidebar">
            <a class="d-block p-2 text-dark text-decoration-none" asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
            <a class="d-block p-2 text-dark text-decoration-none" asp-controller="Profile" asp-action="Index"><i class="bi bi-person-circle me-2"></i>Profile</a>
            <a class="d-block p-2 text-dark text-decoration-none" asp-controller="Wallets" asp-action="Index"><i class="bi bi-wallet2 me-2"></i>Wallet</a>
            <a class="d-block p-2 text-dark text-decoration-none" asp-controller="Properties" asp-action="Index"><i class="bi bi-buildings me-2"></i>Properties</a>
            <a class="d-block p-2 text-dark text-decoration-none" asp-controller="Investments" asp-action="Index"><i class="bi bi-graph-up-arrow me-2"></i>Portfolio</a>
            <a class="d-block p-2 text-dark text-decoration-none" asp-controller="SaleListings" asp-action="Index"><i class="bi bi-shop me-2"></i>Marketplace</a>
        </div>

        <!-- Body -->
        <div class="d-flex gap-3 align-items-start">

            <!-- Sidebar - only visible on desktop -->
            <div class="bg-white rounded shadow-sm p-3 d-none d-md-block" style="min-width: 200px;">
                <a class="d-block p-2 text-dark text-decoration-none" asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
                <a class="d-block p-2 text-dark text-decoration-none" asp-controller="Profile" asp-action="Index"><i class="bi bi-person-circle me-2"></i>Profile</a>
                <a class="d-block p-2 text-dark text-decoration-none" asp-controller="Wallets" asp-action="Index"><i class="bi bi-wallet2 me-2"></i>Wallet</a>
                <a class="d-block p-2 text-dark text-decoration-none" asp-controller="Properties" asp-action="Index"><i class="bi bi-buildings me-2"></i>Properties</a>
                <a class="d-block p-2 text-dark text-decoration-none" asp-controller="Investments" asp-action="Index"><i class="bi bi-graph-up-arrow me-2"></i>Portfolio</a>
                <a class="d-block p-2 text-dark text-decoration-none" asp-controller="SaleListings" asp-action="Index"><i class="bi bi-shop me-2"></i>Marketplace</a>
            </div>

            <!-- Main Content -->
            <div class="flex-grow-1">
                @RenderBody()
            </div>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>